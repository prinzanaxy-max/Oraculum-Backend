generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum BookStatus {
  AVAILABLE
  MISSING
  BORROWED
  RESERVED
  MAINTENANCE
}

model User {
  id             String   @id @default(uuid())
  fullName       String
  studentStaffId String   @unique
  email          String   @unique
  phone          String?
  avatarUrl      String?
  passwordHash   String?
  googleId       String?  @unique
  authProvider   String   @default("local")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  RefreshTokens RefreshToken[]
}

model RefreshToken {
  id        String    @id @default(uuid())
  tokenHash String    @unique
  userId    String
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  User User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Admin {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
}

model Book {
  id            String   @id @default(uuid())
  title         String
  author        String
  isbn          String   @unique
  category      String
  publishedYear Int
  description   String?
  totalCopies   Int
  shelfLocation String?
  status        BookStatus @default(AVAILABLE)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  BorrowRecords BorrowRecord[]
  Reservations  Reservation[]
}

model Member {
  id         String   @id @default(uuid())
  studentId  String   @unique
  memberCode String?  @unique
  registerId String?  @unique
  name       String
  email      String   @unique
  phone      String?
  department String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())

  BorrowRecords BorrowRecord[]
  Reservations  Reservation[]
}

model BorrowRecord {
  id         String   @id @default(uuid())
  bookId     String
  memberId   String
  borrowDate DateTime @default(now())
  dueDate    DateTime
  returnDate DateTime?
  status     String   @default("BORROWED") // BORROWED, RETURNED, OVERDUE
  fineAmount Float    @default(0.0)
  finePaid   Boolean  @default(false)
  fineStatus String   @default("pending") // pending, paid, waived
  createdAt  DateTime @default(now())

  Book   Book   @relation(fields: [bookId], references: [id])
  Member Member @relation(fields: [memberId], references: [id])
}

model VisitorLog {
  id        String   @id @default(uuid())
  visitedAt DateTime @default(now())
}

model Reservation {
  id            String   @id @default(uuid())
  bookId        String
  memberId      String
  status        String   @default("PENDING") // PENDING, READY_FOR_PICKUP, FULFILLED, CANCELLED
  queuePosition Int      @default(0)
  reservedAt    DateTime @default(now())
  readyForPickupAt DateTime?
  pickupExpiresAt  DateTime?
  updatedAt     DateTime @updatedAt

  Book   Book   @relation(fields: [bookId], references: [id])
  Member Member @relation(fields: [memberId], references: [id])
}

model LibrarySettings {
  id                       String   @id @default("default")
  loanPeriodDays           Int      @default(14)
  finePerDay               Float    @default(1)
  maxReservationsPerMember Int      @default(5)
  autoNotifyOverdue        Boolean  @default(true)
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
}

model SupportRequest {
  id        String   @id @default(uuid())
  subject   String
  message   String
  userId    String?
  userEmail String?
  createdAt DateTime @default(now())
}