{
  "info": {
    "name": "Oraculum Backend API",
    "description": "Postman collection for the Oraculum Express + TypeScript backend. Run Signup first to create a test user and store a JWT in the collection variables.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "testEmail",
      "value": ""
    },
    {
      "key": "testPassword",
      "value": "Password123!"
    },
    {
      "key": "studentStaffId",
      "value": ""
    },
    {
      "key": "bookId",
      "value": ""
    },
    {
      "key": "memberId",
      "value": ""
    },
    {
      "key": "dueDate",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Signup",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const timestamp = Date.now();",
                  "pm.collectionVariables.set('testEmail', `postman-${timestamp}@oraculum.edu.gh`);",
                  "pm.collectionVariables.set('studentStaffId', `PM-${timestamp}`);"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Signup returns 201', () => pm.response.to.have.status(201));",
                  "const body = pm.response.json();",
                  "pm.test('Signup returns JWT', () => pm.expect(body.token).to.be.a('string').and.not.empty);",
                  "pm.collectionVariables.set('token', body.token);"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Postman Tester\",\n  \"studentStaffId\": \"{{studentStaffId}}\",\n  \"email\": \"{{testEmail}}\",\n  \"password\": \"{{testPassword}}\",\n  \"confirmPassword\": \"{{testPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/signup",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "signup"]
            },
            "description": "Creates a test user, returns a JWT, and saves it to `token`."
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Login returns 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('Login returns JWT', () => pm.expect(body.token).to.be.a('string').and.not.empty);",
                  "pm.collectionVariables.set('token', body.token);"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{testEmail}}\",\n  \"password\": \"{{testPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            },
            "description": "Authenticates with the test user created by Signup."
          }
        },
        {
          "name": "Me",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/auth/me",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "me"]
            },
            "description": "Returns the authenticated user's public profile."
          }
        }
      ]
    },
    {
      "name": "Books",
      "item": [
        {
          "name": "Get Books",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Get books returns 200', () => pm.response.to.have.status(200));",
                  "const books = pm.response.json();",
                  "if (Array.isArray(books) && books.length) pm.collectionVariables.set('bookId', books[0].id);"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/books",
              "host": ["{{baseUrl}}"],
              "path": ["api", "books"]
            }
          }
        },
        {
          "name": "Create Book",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Create book returns 201', () => pm.response.to.have.status(201));",
                  "const book = pm.response.json();",
                  "pm.collectionVariables.set('bookId', book.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Beloved\",\n  \"author\": \"Toni Morrison\",\n  \"isbn\": \"978-1400033416-{{$timestamp}}\",\n  \"category\": \"Fiction\",\n  \"publishedYear\": 1987,\n  \"description\": \"A Pulitzer Prize-winning novel by Toni Morrison.\",\n  \"totalCopies\": 2,\n  \"status\": \"AVAILABLE\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/books",
              "host": ["{{baseUrl}}"],
              "path": ["api", "books"]
            }
          }
        }
      ]
    },
    {
      "name": "Members",
      "item": [
        {
          "name": "Get Members",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Get members returns 200', () => pm.response.to.have.status(200));",
                  "const members = pm.response.json();",
                  "if (Array.isArray(members) && members.length) pm.collectionVariables.set('memberId', members[0].id);"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/members",
              "host": ["{{baseUrl}}"],
              "path": ["api", "members"]
            }
          }
        },
        {
          "name": "Create Member",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const suffix = Date.now();",
                  "pm.collectionVariables.set('memberCode', `M-${String(suffix).slice(-4)}`);",
                  "pm.collectionVariables.set('memberStudentId', `MEM-${suffix}`);",
                  "pm.collectionVariables.set('memberEmail', `member-${suffix}@oraculum.edu.gh`);"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Create member returns 201', () => pm.response.to.have.status(201));",
                  "const member = pm.response.json();",
                  "pm.collectionVariables.set('memberId', member.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"studentId\": \"{{memberStudentId}}\",\n  \"memberCode\": \"{{memberCode}}\",\n  \"name\": \"Postman Member\",\n  \"email\": \"{{memberEmail}}\",\n  \"phone\": \"+233-20-555-9000\",\n  \"department\": \"Computer Science\",\n  \"isActive\": true\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/members",
              "host": ["{{baseUrl}}"],
              "path": ["api", "members"]
            }
          }
        }
      ]
    },
    {
      "name": "Borrow",
      "item": [
        {
          "name": "Get Borrow Records",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/borrow",
              "host": ["{{baseUrl}}"],
              "path": ["api", "borrow"]
            }
          }
        },
        {
          "name": "Create Borrow Record",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const dueDate = new Date();",
                  "dueDate.setDate(dueDate.getDate() + 14);",
                  "pm.collectionVariables.set('dueDate', dueDate.toISOString());"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"bookId\": \"{{bookId}}\",\n  \"memberId\": \"{{memberId}}\",\n  \"dueDate\": \"{{dueDate}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/borrow",
              "host": ["{{baseUrl}}"],
              "path": ["api", "borrow"]
            },
            "description": "Run Get/Create Book and Get/Create Member first so `bookId` and `memberId` are available."
          }
        }
      ]
    },
    {
      "name": "Reservations",
      "item": [
        {
          "name": "Get Reservations",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/reservations",
              "host": ["{{baseUrl}}"],
              "path": ["api", "reservations"]
            }
          }
        },
        {
          "name": "Create Reservation",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"bookId\": \"{{bookId}}\",\n  \"memberId\": \"{{memberId}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/reservations",
              "host": ["{{baseUrl}}"],
              "path": ["api", "reservations"]
            },
            "description": "Run Get/Create Book and Get/Create Member first so `bookId` and `memberId` are available."
          }
        }
      ]
    },
    {
      "name": "Dashboard",
      "item": [
        {
          "name": "Stats",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/dashboard/stats?range=last_6_months",
              "host": ["{{baseUrl}}"],
              "path": ["api", "dashboard", "stats"],
              "query": [
                {
                  "key": "range",
                  "value": "last_6_months"
                }
              ]
            }
          }
        },
        {
          "name": "Checkout Stats",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/dashboard/checkout-stats?range=last_6_months",
              "host": ["{{baseUrl}}"],
              "path": ["api", "dashboard", "checkout-stats"],
              "query": [
                {
                  "key": "range",
                  "value": "last_6_months"
                }
              ]
            }
          }
        },
        {
          "name": "Overdue History",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/dashboard/overdue-history?limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "dashboard", "overdue-history"],
              "query": [
                {
                  "key": "limit",
                  "value": "10"
                }
              ]
            }
          }
        },
        {
          "name": "Recent Checkouts",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/dashboard/recent-checkouts?limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "dashboard", "recent-checkouts"],
              "query": [
                {
                  "key": "limit",
                  "value": "10"
                }
              ]
            }
          }
        },
        {
          "name": "Books Panel - Top",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/dashboard/books-panel?tab=top&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "dashboard", "books-panel"],
              "query": [
                {
                  "key": "tab",
                  "value": "top"
                },
                {
                  "key": "limit",
                  "value": "10"
                }
              ]
            }
          }
        },
        {
          "name": "Books Panel - New",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/dashboard/books-panel?tab=new&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "dashboard", "books-panel"],
              "query": [
                {
                  "key": "tab",
                  "value": "new"
                },
                {
                  "key": "limit",
                  "value": "10"
                }
              ]
            }
          }
        }
      ]
    }
  ]
}
